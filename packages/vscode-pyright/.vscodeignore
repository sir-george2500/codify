# Ignore all node_modules at any level
**/node_modules/**

# Ignore build artifacts
out/**
dist/**
build/**
.webpack_cache/**

# Ignore source and config files (since we bundle)
src/**
tsconfig.json
webpack.config.js
package-lock.json
packages.config
sign.proj

# Ignore IDE files
.vscode/**
.vscode-test/**
.editorconfig
.eslintrc.json
.prettierrc*
.gitignore

# Ignore documentation and tests
docs/**
tests/**
CHANGELOG.md

# Ignore packaged extensions
*.vsix

# Whitelist necessary files in dist
!dist/extension.js
!dist/server.js
!dist/typeshed-fallback/**
