        "shx": "^0.4.0",
        "ts-loader": "^9.5.4",
        "typescript": "~5.5.4",
        "webpack": "^5.102.1",
        "webpack-cli": "^5.1.4"
    },
    "files": [
        "/dist",
        "LICENSE.txt"
    ],
    "main": "index.js",
    "bin": {
        "pyright": "index.js",
        "pyright-langserver": "langserver.index.js"
    }
