        "webpack": "webpack --mode development --progress"
    },
    "optionalDependencies": {
        "fsevents": "~2.3.3"
    },
    "devDependencies": {
        "@types/node": "^22.18.12",
        "copy-webpack-plugin": "^12.0.2",
